# Copy file này thành .env và điền giá trị thật. Không commit file .env.
# Trên Windows: copy .env.example .env
# Trên Linux/Mac: cp .env.example .env

# PostgreSQL (bắt buộc)
# Ví dụ: Host=localhost;Port=5432;Database=anphucnienso;Username=postgres;Password=YOUR_PASSWORD
CONNECTIONSTRINGS__DEFAULTCONNECTION=

# JWT (bắt buộc) — chuỗi bí mật ≥ 32 ký tự
JWTSETTINGS__SECRET=
