# ── An Phúc Niên Sổ — Frontend Environment Config ──
#
# Copy this file to .env.development or .env.local and adjust as needed.
# Vite exposes only variables prefixed with VITE_ to the browser.
#
# Backend API base URL (no trailing slash)
#
#   • Local API (backend chạy trên máy):
#     VITE_API_URL=http://localhost:5018
#
#   • Production API (test UI local với API production):
#     VITE_API_URL=https://anphucnien.okdimall.com
#
VITE_API_URL=http://localhost:5018
